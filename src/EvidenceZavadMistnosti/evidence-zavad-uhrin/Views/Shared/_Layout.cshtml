@using Microsoft.AspNetCore.Authentication.Cookies
@using Microsoft.AspNetCore.Authentication
@using Microsoft.AspNetCore.Authorization
@using System.Security.Claims
@{
    var isAuth = User?.Identity?.IsAuthenticated ?? false;
    var username = isAuth ? User.Identity!.Name : null;
}
<!DOCTYPE html>
<html lang="cs">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <title>@ViewData["Title"] - Evidence závad</title>
    <link rel="stylesheet" href="~/css/style.css" asp-append-version="true" />
</head>
<body>
    <div class="site-shell">
        <header class="site-header">
            <div class="site-header__inner">
                <div class="site-branding">
                    <a class="site-logo" asp-controller="Home" asp-action="Index">
                        <span class="site-logo__mark">EZ</span>
                        <span class="site-logo__text">
                            <strong>Evidence závad</strong>
                            <small>Správa místností a hlášení problémů</small>
                        </span>
                    </a>

                    @if (isAuth)
                    {
                        <nav class="site-nav" aria-label="Hlavní navigace">
                            <a class="site-nav__link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Rooms" ? "is-active" : "")"
                               asp-controller="Rooms" asp-action="Index">
                                Místnosti
                            </a>
                            <a class="site-nav__link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Issues" ? "is-active" : "")"
                               asp-controller="Issues" asp-action="Index">
                                Závady
                            </a>
                        </nav>
                    }
                </div>

                <div class="site-user-panel">
                    @if (isAuth)
                    {
                        <div class="site-user-badge">
                            <span class="site-user-badge__label">Přihlášený uživatel</span>
                            <strong>@username</strong>
                        </div>

                        <form asp-controller="Account" asp-action="Logout" method="post" class="site-logout-form">
                            @Html.AntiForgeryToken()
                            <button class="btn btn-ghost" type="submit">Odhlásit</button>
                        </form>
                    }
                    else
                    {
                        <a class="btn btn-ghost" asp-controller="Account" asp-action="Login">Přihlásit se</a>
                        <a class="btn btn-primary" asp-controller="Account" asp-action="Register">Registrovat</a>
                    }
                </div>
            </div>
        </header>

        <main class="site-main">
            @RenderBody()
        </main>
    </div>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
